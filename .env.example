# Local development environment variables.
# Copy this file to .env and fill in real values. `.env` is gitignored.
#
# Used by docker-compose.yml.

# Postgres password for the local Docker Postgres container.
# Pick any strong value — it only protects your local DB.
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Cloudflare Tunnel token (only set if you want a NAMED tunnel instead of
# the random *.trycloudflare.com URL). Get it from:
#   Cloudflare dashboard → Zero Trust → Networks → Tunnels → your tunnel → Configure
# When this is set AND docker-compose uses the named-tunnel command, your
# laptop is reachable at the public hostnames you configured (e.g. finance.manhou.de).
CLOUDFLARE_TUNNEL_TOKEN=

# Firebase App Check verification. Both values come from Firebase Console →
# Project Settings → General. The "Project number" is the same value shown
# in the web SDK config as `messagingSenderId`; the "App ID" is shown on the
# same page ("Your apps" section).
#
# When both are set, the backend registers AppCheckMiddleware and validates
# the X-Firebase-AppCheck header on every request. APPCHECK_ENFORCE defaults
# to false (log-only) so legitimate clients aren't rejected during rollout.
# Flip to true after 48h of clean violation logs.
FIREBASE_PROJECT_NUMBER=
FIREBASE_APP_ID=
APPCHECK_ENFORCE=false

# Phase 3b — lockout email notifications (Resend) + IP soft-block.
#
# RESEND_API_KEY: Get from https://resend.com → API Keys (free tier).
#   Leave blank in dev — system uses NoOpEmailSender that just logs.
# RESEND_FROM_ADDRESS: must be on a domain you've verified at Resend
#   (SPF + DKIM DNS records). Defaults to noreply@manhou.de.
# ADMIN_ALERT_EMAIL: where to send "someone is probing the system" alerts.
# RESET_PASSWORD_URL: link inserted into user-alert emails.
# LOCKOUT_ALERTS_ENABLED: master kill switch. Set to false to disable
#   without redeploying.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@manhou.de
ADMIN_ALERT_EMAIL=wenhaoyuan02@gmail.com
RESET_PASSWORD_URL=https://finance.manhou.de/forgot-password
LOCKOUT_ALERTS_ENABLED=true

# Auto-deploy agent — polls origin/main and rebuilds backend + frontend
# when new commits land. Defaults are sensible for production use.
#   DEPLOY_POLL_INTERVAL_SECONDS: how often to check (default 300 = 5 min)
#   DEPLOY_GIT_BRANCH: branch to track (default main)
DEPLOY_POLL_INTERVAL_SECONDS=300
DEPLOY_GIT_BRANCH=main
