# Local development environment variables.
# Copy this file to .env and fill in real values. `.env` is gitignored.
#
# Used by docker-compose.yml.

# Postgres password for the local Docker Postgres container.
# Pick any strong value — it only protects your local DB.
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Cloudflare Tunnel token (only set if you want a NAMED tunnel instead of
# the random *.trycloudflare.com URL). Get it from:
#   Cloudflare dashboard → Zero Trust → Networks → Tunnels → your tunnel → Configure
# When this is set AND docker-compose uses the named-tunnel command, your
# laptop is reachable at the public hostnames you configured (e.g. finance.manhou.de).
CLOUDFLARE_TUNNEL_TOKEN=

# Firebase App Check verification. Both values come from Firebase Console →
# Project Settings → General. The "Project number" is the same value shown
# in the web SDK config as `messagingSenderId`; the "App ID" is shown on the
# same page ("Your apps" section).
#
# When both are set, the backend registers AppCheckMiddleware and validates
# the X-Firebase-AppCheck header on every request. APPCHECK_ENFORCE defaults
# to false (log-only) so legitimate clients aren't rejected during rollout.
# Flip to true after 48h of clean violation logs.
FIREBASE_PROJECT_NUMBER=
FIREBASE_APP_ID=
APPCHECK_ENFORCE=false
